# Copy this file to `.env` in the SAME folder (jenkins/.env) and fill in real values.
# jenkins/docker-compose.yml reads jenkins/.env automatically.
# NEVER commit the real .env file — make sure "jenkins/.env" is in .gitignore.

# --- Jenkins admin login (JCasC: jenkins.securityRealm.local.users) ---
# Any strong password you choose yourself for logging into the Jenkins UI.
ADMIN_PASSWORD=

# --- Slack notifications (JCasC: credentials.slack-webhook + unclassified.slackNotifier) ---
# Get from: Slack -> https://api.slack.com/apps -> your app -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/DISABLED/DISABLED/DISABLED


# --- AWS credentials (JCasC: credentials.aws-credentials) ---
# Get from: AWS Console -> IAM -> Users -> select user -> Security credentials -> Create access key
# Needs permissions for: ECR (push/pull images)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# --- GitHub credentials (JCasC: credentials.github-credentials) ---
# Used by the pipelineJob in casc.yml to checkout the repo over HTTPS.
# Get token from: GitHub -> Settings -> Developer settings -> Personal access tokens
#   -> Generate new token (fine-grained or classic) -> scope: repo (read)
GITHUB_USERNAME=
GITHUB_TOKEN=
